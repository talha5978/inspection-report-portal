{
	"name": "inspection-report-portal",
	"version": "1.0.0",
	"private": true,
	"description": "Client Portal + QR Code Document Access System",
	"scripts": {
		"dev": "dotenv -- turbo run dev",
		"build": "dotenv -- turbo run build",
		"start": "dotenv -- turbo run start",
		"backend:dev": "dotenv -- turbo run dev --filter=@inspection-report-portal/backend",
		"backend:build": "dotenv -- turbo run build --filter=@inspection-report-portal/backend",
		"backend:start": "dotenv -- turbo run start --filter=@inspection-report-portal/backend",
		"client:dev": "dotenv -- turbo run dev --filter=@inspection-report-portal/client-portal",
		"client:build": "dotenv -- turbo run build --filter=@inspection-report-portal/client-portal",
		"client:start": "dotenv -- turbo run start --filter=@inspection-report-portal/client-portal",
		"admin:dev": "dotenv -- turbo run dev --filter=@inspection-report-portal/admin-portal",
		"admin:build": "dotenv -- turbo run build --filter=@inspection-report-portal/admin-portal",
		"admin:start": "dotenv -- turbo run start --filter=@inspection-report-portal/admin-portal",
		"format": "prettier . --write \"**/*.{js,ts,tsx,jsx,json,md,css,scss,yaml}\"",
		"db:generate": "dotenv -- turbo run db:generate --filter=@inspection-report-portal/db",
		"db:migrate": "dotenv -- turbo run db:migrate --filter=@inspection-report-portal/db",
		"db:push": "dotenv -- turbo run db:push --filter=@inspection-report-portal/db"
	},
	"lint-staged": {
		"*.{js,ts,tsx,jsx,json,md,css,scss,yaml}": "prettier --write"
	},
	"devDependencies": {
		"dotenv-cli": "^11.0.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"prettier": "3.9.0",
		"turbo": "^2.0.0"
	},
	"packageManager": "pnpm@11.1.1",
	"type": "module",
	"keywords": [
		"inspection-report",
		"qr-code",
		"document-management",
		"equipment-inspection",
		"client-portal",
		"pdf-management",
		"google-drive",
		"clerk-auth",
		"drizzle-orm",
		"fastify",
		"react-router",
		"monorepo",
		"turborepo",
		"pnpm-workspaces"
	]
}
