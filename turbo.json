{
	"$schema": "https://turbo.build/schema.json",
	"globalEnv": [
		"NODE_ENV",
		"VITE_ENV",
		"BACKEND_PORT",
		"ADMIN_PORTAL_URL",
		"CLIENT_PORTAL_URL",
		"API_BASE_URL",
		"PG_CONNECTION_STRING",
		"CLERK_PUBLISHABLE_KEY",
		"CLERK_SECRET_KEY",
		"CLERK_JWT_KEY",
		"CLERK_SIGN_IN_URL",
		"CLERK_SIGN_UP_URL",
		"GOOGLE_CLIENT_ID",
		"GOOGLE_CLIENT_SECRET",
		"GOOGLE_REDIRECT_URI",
		"GOOGLE_REFRESH_TOKEN",
		"GOOGLE_DRIVE_FOLDER_ID"
	],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".react-router/**", "dist/**", "build/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"start": {
			"cache": false,
			"persistent": true
		},
		"lint": {},
		"db:generate": {
			"cache": false
		},
		"db:migrate": {
			"cache": false
		},
		"db:push": {
			"cache": false
		}
	}
}
