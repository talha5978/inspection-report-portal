{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".react-router/**", "dist/**", "build/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"lint": {},
		"db:generate": {
			"cache": false
		},
		"db:migrate": {
			"cache": false
		}
	}
}
